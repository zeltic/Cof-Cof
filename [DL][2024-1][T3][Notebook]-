: {e.stderr.decode()}\")\n        return False\n\ndef create_spectrogram(wav_file, output_image): # Creo espectrogramas de los audios\n    y, sr = librosa.load(wav_file, sr=None)\n    S = librosa.feature.melspectrogram(y=y, sr=sr)\n    S_dB = librosa.power_to_db(S, ref=np.max)\n\n    plt.figure(figsize=(10, 4))\n    librosa.display.specshow(S_dB, sr=sr, x_axis='time', y_axis='mel')\n    plt.colorbar(format='%+2.0f dB')\n    plt.title('Mel-frequency spectrogram')\n    plt.tight_layout()\n    plt.savefig(output_image)\n    plt.close()\n\ndef process_batch(c, files, output_dir):\n    for file_path in files:\n        filename = os.path.basename(file_path)\n        if filename.endswith(\".webm\"): # Si el archivo es .webm\n            wav_filename = filename.replace(\".webm\", \".wav\")\n            wav_path = os.path.join(output_dir, wav_filename)\n            image_filename = filename.replace(\".webm\", \".png\")\n            image_path = os.path.join(output_dir, image_filename)\n        elif filename.endswith(\".ogg\"): # Si el archivo es .ogg\n            wav_filename = filename.replace(\".ogg\", \".wav\")\n            wav_path = os.path.join(output_dir, wav_filename)\n            image_filename = filename.replace(\".ogg\", \".png\")\n            image_path = os.path.join(output_dir, image_filename)\n        else: # Si el archivo es .wav\n            wav_filename = filename\n            wav_path = os.path.join(output_dir, wav_filename)\n            image_filename = filename.replace(\".wav\", \".png\")\n            image_path = os.path.join(output_dir, image_filename)\n        \n        if os.path.exists(image_path): # Si el espectrograma ya existe\n            continue\n\n        if filename.endswith(\".webm\"): # Si el archivo es .webm\n            if convert_webm_to_wav_ffmpeg(file_path, wav_path):\n                create_spectrogram(wav_path, image_path)\n                os.remove(wav_path)\n            else:\n                print(f\"Skipping {file_path} due to conversion error.\")\n        elif filename.endswith(\".ogg\"): # Si el archivo es .ogg\n            if convert_ogg_to_wav_ffmpeg(file_path, wav_path):\n                create_spectrogram(wav_path, image_path)\n                os.remove(wav_path)\n            else:\n                print(f\"Skipping {file_path} due to conversion error.\")\n        else: # Si el archivo es .wav\n            create_spectrogram(file_path, image_path)\n\ndef process_files_in_batches(input_dir, output_dir, batch_size): # Separo el proceso en batches para no quedarme sin RAM\n    if not os.path.exists(output_dir):\n        os.makedirs(output_dir)\n\n    all_files = [os.path.join(input_dir, f) for f in os.listdir(input_dir) if f.endswith((\".webm\", \".wav\", \".ogg\"))]\n    \n    for i in range(0, len(all_files), batch_size):\n        batch_files = all_files[i:i+batch_size]\n        print(f\"Processing batch {i//batch_size + 1} / {len(all_files)//batch_size + 1}\")\n        c = [1]\n        with multiprocessing.Pool(1) as pool: pool.starmap(process_batch, zip(c, repeat(batch_files), repeat(output_dir)))\n\ninput_directory = \"/kaggle/input/udp-dl-trabajo-3-covid-19/audio/\"\noutput_directory = \"/kaggle/working/espectrograma/\"\nbatch_size = 1000\n\nprocess_files_in_batches(input_directory, output_directory, batch_size)\n\ninput_directory = \"/kaggle/input/covid19-cough-audio-classification\"\n\nprocess_files_in_batches(input_directory, output_directory, batch_size)","metadata":{"execution":{"iopub.status.busy":"2024-06-24T01:58:50.107499Z","iopub.execute_input":"2024-06-24T01:58:50.107973Z","iopub.status.idle":"2024-06-24T01:58:52.545583Z","shell.execute_reply.started":"2024-06-24T01:58:50.107934Z","shell.execute_reply":"2024-06-24T01:58:52.544548Z"},"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import numpy as np\nimport pandas as pd\nimport os\nimport tensorflow as tf\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.preprocessing 